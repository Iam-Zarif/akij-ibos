{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.next/**": true,
    "**/node_modules/**": true,
    "**/.vercel/**": true
  },
  "search.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/.vercel": true
  },
  "files.exclude": {
    "**/.next": true
  },
  "typescript.tsserver.watchOptions": {
    "watchFile": "useFsEventsOnParentDirectory",
    "watchDirectory": "useFsEvents",
    "fallbackPolling": "dynamicPriority"
  }
}
